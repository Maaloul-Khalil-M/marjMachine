{
	// Place your snippets for javascript here. Each snippet is defined under a snippet name and has a prefix, body and
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
  "Function Expression": {
    "prefix": "fn",
    "body": [
      "const ${1:name} = function(${2:params}) {",
      "\t${0}",
      "};"
    ],
    "description": "Function expression"
  },

  "Arrow Function": {
    "prefix": "afn",
    "body": [
      "const ${1:name} = (${2:params}) => {",
      "\t${0}",
      "};"
    ],
    "description": "Arrow function"
  },

  "For Loop (index)": {
    "prefix": "fori",
    "body": [
      "for (let i = 0; i < ${1:array}.length; i++) {",
      "\tconst ${2:item} = ${1:array}[i];",
      "\t${0}",
      "}"
    ],
    "description": "For loop with index"
  },

  "For...of Loop": {
    "prefix": "foro",
    "body": [
      "for (const ${1:item} of ${2:iterable}) {",
      "\t${0}",
      "}"
    ],
    "description": "For of loop"
  },

  "While Loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t${0}",
      "}"
    ],
    "description": "While loop"
  },

  "If Statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t${0}",
      "}"
    ],
    "description": "If statement"
  },

  "If Else": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) {",
      "\t${2}",
      "} else {",
      "\t${0}",
      "}"
    ],
    "description": "If else statement"
  },

  "Try Catch": {
    "prefix": "try",
    "body": [
      "try {",
      "\t${1}",
      "} catch (err) {",
      "\tconsole.error(err);",
      "\t${0}",
      "}"
    ],
    "description": "Try/catch block"
  },

  "Console Log": {
    "prefix": "log",
    "body": [
      "console.log(${1});"
    ],
    "description": "Console log"
  },

  "Map": {
    "prefix": "map",
    "body": [
      "${1:array}.map((${2:item}) => {",
      "\t${0}",
      "});"
    ],
    "description": "Array map"
  },

  "Filter": {
    "prefix": "filter",
    "body": [
      "${1:array}.filter((${2:item}) => {",
      "\treturn ${0};",
      "});"
    ],
    "description": "Array filter"
  },

  "Reduce": {
    "prefix": "reduce",
    "body": [
      "${1:array}.reduce((${2:acc}, ${3:item}) => {",
      "\t${0}",
      "}, ${4:initial});"
    ],
    "description": "Array reduce"
  },
  "Class": {
    "prefix": "cl",
    "body": [
      "class ${1:ClassName} {",
      "\tconstructor(${2:params}) {",
      "\t\t${0}",
      "\t}",
      "}"
    ],
    "description": "Class template"
  },

  "Constructor Only": {
    "prefix": "ctor",
    "body": [
      "constructor(${1:params}) {",
      "\t${0}",
      "}"
    ],
    "description": "Constructor block"
  },

  "Import Module": {
    "prefix": "imp",
    "body": [
      "import { ${1:module} } from '${2:path}';"
    ],
    "description": "ES module import"
  },

  "Export Named": {
    "prefix": "exp",
    "body": [
      "export { ${1:name} };"
    ],
    "description": "Named export"
  },

  "Export Default": {
    "prefix": "expd",
    "body": [
      "export default ${1:name};"
    ],
    "description": "Default export"
  },

  "Async Function": {
    "prefix": "async",
    "body": [
      "async function ${1:name}(${2:params}) {",
      "\ttry {",
      "\t\t${0}",
      "\t} catch (err) {",
      "\t\tconsole.error(err);",
      "\t}",
      "}"
    ],
    "description": "Async function with try/catch"
  },

  "Async Arrow Function": {
    "prefix": "aafn",
    "body": [
      "const ${1:name} = async (${2:params}) => {",
      "\ttry {",
      "\t\t${0}",
      "\t} catch (err) {",
      "\t\tconsole.error(err);",
      "\t}",
      "}"
    ],
    "description": "Async arrow function"
  },

  "Fetch API": {
    "prefix": "fetch",
    "body": [
      "const res = await fetch('${1:url}', {",
      "\tmethod: '${2|GET,POST,PUT,DELETE|}',",
      "\theaders: {",
      "\t\t'Content-Type': 'application/json'",
      "\t},",
      "\tbody: JSON.stringify(${3:data})",
      "});",
      "",
      "const data = await res.json();",
      "${0}"
    ],
    "description": "Fetch API template"
  },

  "Promise": {
    "prefix": "promise",
    "body": [
      "return new Promise((resolve, reject) => {",
      "\t${0}",
      "});"
    ],
    "description": "Promise wrapper"
  },

  "Set Timeout": {
    "prefix": "timer",
    "body": [
      "setTimeout(() => {",
      "\t${0}",
      "}, ${1:delay});"
    ],
    "description": "setTimeout"
  },

  "Set Interval": {
    "prefix": "interval",
    "body": [
      "setInterval(() => {",
      "\t${0}",
      "}, ${1:delay});"
    ],
    "description": "setInterval"
  },

  "JSON Parse": {
    "prefix": "jparse",
    "body": [
      "JSON.parse(${1:string});"
    ],
    "description": "JSON.parse"
  },

  "JSON Stringify": {
    "prefix": "jstr",
    "body": [
      "JSON.stringify(${1:object}, null, 2);"
    ],
    "description": "JSON.stringify pretty"
  }
}
